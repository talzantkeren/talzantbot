{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "bot",
      "root": "./node-bot",
      "build": {
        "builder": "dockerfile",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "node bot.js"
      }
    },
    {
      "name": "monitor",
      "root": "./python-monitor",
      "build": {
        "builder": "dockerfile",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "python monitor.py"
      }
    }
  ]
}
