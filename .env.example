# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ===== TELEGRAM CLIENT (for channel monitoring)
# Get from: https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# ===== TELEGRAM SESSION STRING (for Railway deployment)
# Generate locally with: python python-monitor/generate_session.py
TELEGRAM_SESSION_STRING=your_session_string_here

# ===== FINLIGHT REAL-TIME NEWS =====
FINLIGHT_API_KEY=sk_your_finlight_key_here

# ===== GOOGLE GEMINI API (for Hebrew translation) =====
GEMINI_API_KEY=your_gemini_api_key_here

# ===== REDIS (for shared deduplication) =====
REDIS_URL=redis://default:password@redis.railway.internal:6379
